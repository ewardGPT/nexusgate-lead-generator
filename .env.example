# n8n Webhook URL (the production endpoint that receives form submissions)
WEBHOOK_URL=https://your-n8n-instance.com/webhook/incoming-lead

# n8n Webhook Secret (for HMAC verification)
WEBHOOK_SECRET=your-webhook-secret-token

# Apify API Token
APIFY_API_TOKEN=your-apify-api-token

# OpenClaw API Configuration
OPENCLAW_API_KEY=your-openclaw-api-key
OPENCLAW_BASE_URL=https://api.openclaw.com/v1
OPENCLAW_MODEL=gpt-4o

# Slack Configuration (for sales alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_ADMIN_CHANNEL=#nexusgate-lead-errors

# Telegram Configuration (alternative to Slack)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Google Sheets Configuration (for lead logging)
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials/google-sa.json
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Email Nurture API (Mailchimp/Loops)
NURTURE_API_KEY=your-nurture-api-key
NURTURE_LIST_ID=your-list-id

# ============================================================
# Outbound Pipeline Configuration
# ============================================================

# Supabase (for logging all outbound leads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Gmail (for sending cold emails from ervin@nexusgate.tech)
GMAIL_OAUTH_CLIENT_ID=your-gmail-oauth-client-id
GMAIL_OAUTH_CLIENT_SECRET=your-gmail-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_SENDER_EMAIL=ervin@nexusgate.tech

# n8n Webhook URLs (exposed to nexusgate.tech frontend)
N8N_AUDIT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/audit-complete
N8N_CALL_BOOKED_WEBHOOK_URL=https://your-n8n-instance.com/webhook/call-booked

# Rate Limiting — max emails per day to protect sender reputation
OUTBOUND_MAX_EMAILS_PER_DAY=50

# GitHub Actions — Trigger the n8n outbound pipeline
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/trigger-outbound-pipeline

# Form Configuration (inbound lead generator — legacy)
FORM_WEBHOOK_URL=https://your-n8n-instance.com/webhook/incoming-lead
FORM_RATE_LIMIT_WINDOW_MS=60000
FORM_RATE_LIMIT_MAX_REQUESTS=10
