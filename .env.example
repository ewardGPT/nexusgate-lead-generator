# n8n Webhook URL (the production endpoint that receives form submissions)
WEBHOOK_URL=https://your-n8n-instance.com/webhook/incoming-lead

# n8n Webhook Secret (for HMAC verification)
WEBHOOK_SECRET=your-webhook-secret-token

# Apify API Token
APIFY_API_TOKEN=your-apify-api-token

# OpenClaw API Configuration
OPENCLAW_API_KEY=your-openclaw-api-key
OPENCLAW_BASE_URL=https://api.openclaw.com/v1
OPENCLAW_MODEL=gpt-4o

# Slack Configuration (for sales alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_ADMIN_CHANNEL=#nexusgate-lead-errors

# Telegram Configuration (alternative to Slack)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Google Sheets Configuration (for lead logging)
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials/google-sa.json
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Email Nurture API (Mailchimp/Loops)
NURTURE_API_KEY=your-nurture-api-key
NURTURE_LIST_ID=your-list-id

# Form Configuration
FORM_WEBHOOK_URL=https://your-n8n-instance.com/webhook/incoming-lead
FORM_RATE_LIMIT_WINDOW_MS=60000
FORM_RATE_LIMIT_MAX_REQUESTS=10
